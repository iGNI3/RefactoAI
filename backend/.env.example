# ─────────────────────────────────────────────────────────────
# Autonomous Code Analyzer — Environment Variables
# Copy this file to `.env` and fill in your keys.
# ─────────────────────────────────────────────────────────────

# LLM Provider API Keys (leave blank to skip that provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# Workspace & Storage Paths
WORKSPACE_ROOT=./sandbox_workspace
CHROMA_DB_PATH=./chroma_db

# PatchPilot — maximum modified lines allowed per diff
MAX_DIFF_LINES=120

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true
